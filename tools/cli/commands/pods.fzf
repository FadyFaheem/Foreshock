#All-in-one: bring up DEV (train if needed -> start pod -> wait -> seed KB)
bash tools/cli/bootstrap.sh dev

#All-in-one: bring up PROD (train if needed -> start pod -> wait -> seed KB)
bash tools/cli/bootstrap.sh prod

#Pre-pull required images
podman pull docker.io/library/node:20-alpine && podman pull docker.io/library/python:3.11-slim && podman pull docker.io/pgvector/pgvector:pg16 && podman pull docker.io/apache/kafka:3.9.0 && podman pull docker.io/ollama/ollama:latest && podman pull docker.io/cloudflare/cloudflared:latest

#Seed the knowledge base in the dev pod
podman exec foreshock-dev-pod-foreshock-api python /app/scripts/seed_kb.py

#Start foreshock-dev pod
podman play kube infra/podman/foreshock-dev.yaml

#Start foreshock-prod pod
podman play kube infra/podman/foreshock-prod.yaml

#Stop foreshock-dev pod
podman pod stop foreshock-dev-pod

#Stop foreshock-prod pod
podman pod stop foreshock-prod-pod

#Delete foreshock-dev pod
podman pod rm -f foreshock-dev-pod

#Delete foreshock-prod pod
podman pod rm -f foreshock-prod-pod

#Rebuild foreshock-dev pod
podman pod rm -f foreshock-dev-pod && podman play kube infra/podman/foreshock-dev.yaml

#Rebuild foreshock-prod pod
podman pod rm -f foreshock-prod-pod && podman play kube infra/podman/foreshock-prod.yaml

#Get pod status
podman pod ps

#List containers in dev pod
podman ps --filter pod=foreshock-dev-pod

#List containers in prod pod
podman ps --filter pod=foreshock-prod-pod

#View dev pod logs (all containers)
podman pod logs foreshock-dev-pod

#Follow dev pod logs in real-time (all containers)
podman pod logs -f foreshock-dev-pod

#View prod pod logs (all containers)
podman pod logs foreshock-prod-pod

#Follow prod pod logs in real-time (all containers)
podman pod logs -f foreshock-prod-pod

#View API container logs (dev)
podman logs foreshock-dev-pod-foreshock-api

#View frontend container logs (dev)
podman logs foreshock-dev-pod-foreshock-frontend

#View API container logs (prod)
podman logs foreshock-prod-pod-foreshock-api

#View frontend container logs (prod)
podman logs foreshock-prod-pod-foreshock-frontend

#View postgres container logs (prod)
podman logs foreshock-prod-pod-postgres-db

#View kafka container logs (prod)
podman logs foreshock-prod-pod-kafka

#View ollama container logs (prod)
podman logs foreshock-prod-pod-ollama

#View cloudflared container logs (prod)
podman logs foreshock-prod-pod-cloudflared

#Access API container shell (dev)
podman exec -it foreshock-dev-pod-foreshock-api bash

#Access frontend container shell (dev)
podman exec -it foreshock-dev-pod-foreshock-frontend sh

#Access API container shell (prod)
podman exec -it foreshock-prod-pod-foreshock-api bash

#Access frontend container shell (prod)
podman exec -it foreshock-prod-pod-foreshock-frontend sh

#Check if required images are pulled
podman images | grep -E "(node|python|pgvector|kafka|ollama|cloudflared)"

#Fix TLS certificate issues - configure registry to skip TLS verification
mkdir -p ~/.config/containers && printf '[[registry]]\nlocation = "docker.io"\ninsecure = true\n' > ~/.config/containers/registries.conf && echo "Registry configured. You may need to restart Podman."
