#AI subsystem status (db / llm / kb)
curl -s http://localhost:8000/api/ai/status

#Diagnose a sample (RAG + LLM)
curl -s -X POST http://localhost:8000/api/diagnose -F "sample_id=inner_race"

#Run the agentic workflow (ball)
curl -s -X POST http://localhost:8000/api/agent -F "sample_id=ball"

#AI observability metrics
curl -s http://localhost:8000/api/observability

#Latest eval report
curl -s http://localhost:8000/api/evals

#Run the eval suite now (via API)
curl -s -X POST http://localhost:8000/api/evals/run

#Recent work orders
curl -s http://localhost:8000/api/work_orders

#Seed the knowledge base in the pod
podman exec foreshock-dev-pod-foreshock-api python /app/scripts/seed_kb.py

#Run evals (host CLI)
python scripts/run_evals.py

#Seed the knowledge base (host CLI)
python scripts/seed_kb.py

#List the Ollama models loaded in the pod
podman exec foreshock-dev-pod-ollama ollama list

#Switch to a lighter LLM (pull qwen2.5:0.5b into the pod)
podman exec foreshock-dev-pod-ollama ollama pull qwen2.5:0.5b

#Follow the in-pod Ollama logs (model pulls / inference)
podman logs -f foreshock-dev-pod-ollama
